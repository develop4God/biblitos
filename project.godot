; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but with care it can be done manually.

config_version=5

[application]

config/name="Biblitos"
config/features=PackedStringArray("4.3", "Mobile")
config/icon="res://icon.svg"

[autoload]

LocaleManager="*res://scripts/managers/locale_manager.gd"
GameState="*res://scripts/managers/game_state.gd"
AudioManager="*res://scripts/managers/audio_manager.gd"
SceneManager="*res://scripts/managers/scene_manager.gd"

[rendering]

renderer/rendering_method="mobile"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=4
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
